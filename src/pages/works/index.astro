---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import WorkCard from '../../components/WorkCard.astro';

const works = (await getCollection('works', ({ data }) => !data.draft)).sort(
  (a, b) => {
    const oa = a.data.order ?? Number.POSITIVE_INFINITY;
    const ob = b.data.order ?? Number.POSITIVE_INFINITY;
    if (oa !== ob) return oa - ob;
    return a.data.title.localeCompare(b.data.title, 'ja');
  }
);
---

<Layout title="作品" description="深野重興 の作品一覧">
  <section class="hero-k hero-k--page">
    <h1 class="hero-k__title reveal reveal-1">作品</h1>
    <p class="hero-k__sub reveal reveal-2">完成・開発中の作品紹介。</p>
  </section>

  <section class="section">
    <div class="wrap rise">
      {
        works.length > 0 ? (
          <div class="grid">
            {works.map((work) => (
              <WorkCard work={work} />
            ))}
          </div>
        ) : (
          <p class="empty">まだ作品が登録されていません。</p>
        )
      }
    </div>
  </section>
</Layout>
