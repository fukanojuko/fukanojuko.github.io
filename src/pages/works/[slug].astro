---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const works = await getCollection('works', ({ data }) => !data.draft);
  return works.map((work) => ({
    params: { slug: work.id }, // id = ファイル名 = slug
    props: { work },
  }));
}

const { work } = Astro.props;
const { Content } = await render(work);
const { title, genre, engine, release, summary, thumbnail, links } = work.data;

// ───────────────────────────────────────────────────────────────
// エンジニア向け: ページ単位のCSS介入口
// src/styles/works/<slug>.css を置くと、そのページにだけ自動で適用される。
// 本文は <body class="work-<slug>"> / <article class="detail work-<slug>"> で
// ラップされるので、CSSは `.work-<slug> { ... }` のようにスコープして書く。
// ───────────────────────────────────────────────────────────────
const pageStyles = import.meta.glob('../../styles/works/*.css', {
  query: '?raw',
  import: 'default',
  eager: true,
}) as Record<string, string>;
const pageCss = pageStyles[`../../styles/works/${work.id}.css`];
---

<Layout
  title={title}
  description={summary}
  image={thumbnail}
  bodyClass={`work-${work.id}`}
>
  {pageCss && <style is:inline set:html={pageCss} slot="head" />}

  <a class="back" href="/works/">← 作品一覧へ戻る</a>

  <article class={`detail work-${work.id}`}>
    {
      thumbnail && (
        <div class="cover">
          <img src={thumbnail} alt={title} />
        </div>
      )
    }

    <h1>{title}</h1>

    <ul class="meta">
      {genre && <li><span>ジャンル</span>{genre}</li>}
      {engine && <li><span>エンジン</span>{engine}</li>}
      {release && <li><span>リリース</span>{release}</li>}
    </ul>

    {
      links && (links.store || links.site || links.x) && (
        <div class="links">
          {links.store && (
            <a href={links.store} target="_blank" rel="noopener">
              ストア
            </a>
          )}
          {links.site && (
            <a href={links.site} target="_blank" rel="noopener">
              公式サイト
            </a>
          )}
          {links.x && (
            <a href={links.x} target="_blank" rel="noopener">
              X
            </a>
          )}
        </div>
      )
    }

    <div class="prose">
      <Content />
    </div>
  </article>
</Layout>
