---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import DesignCard from '../../components/DesignCard.astro';

const designs = (await getCollection('designs', ({ data }) => !data.draft)).sort(
  (a, b) => {
    const d = (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0);
    if (d !== 0) return d;
    const oa = a.data.order ?? Number.POSITIVE_INFINITY;
    const ob = b.data.order ?? Number.POSITIVE_INFINITY;
    return oa - ob;
  }
);
---

<Layout title="デザイン" description="深野重興 のデザインラフ・WIP">
  <section class="hero-k hero-k--page">
    <h1 class="hero-k__title reveal reveal-1">デザイン</h1>
    <p class="hero-k__sub reveal reveal-2">デザインラフ・WIP の共有。</p>
  </section>

  <section class="section">
    <div class="wrap rise">
      {
        designs.length > 0 ? (
          <div class="grid">
            {designs.map((design) => (
              <DesignCard design={design} />
            ))}
          </div>
        ) : (
          <p class="empty">まだデザインが登録されていません。</p>
        )
      }
    </div>
  </section>
</Layout>
