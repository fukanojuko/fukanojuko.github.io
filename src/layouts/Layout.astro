---
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

interface Props {
  title: string;
  description?: string;
  image?: string; // OGP用。public配下の絶対パス（例: /images/foo.png）
  bodyClass?: string; // ページ単位でスタイルをスコープしたいとき用
}

const {
  title,
  description = SITE_DESCRIPTION,
  image,
  bodyClass = '',
} = Astro.props;

const pageTitle = title === SITE_TITLE ? title : `${title}｜${SITE_TITLE}`;
const ogImage = image ? new URL(image, Astro.site).toString() : undefined;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <!-- ページ個別の <head> 追加用スロット（任意） -->
    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <header class="site-header">
      <div class="inner">
        <a href="/" class="brand">{SITE_TITLE}</a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="inner">© {year} {SITE_TITLE}</div>
    </footer>

    <style is:global>
      :root {
        --bg: #0e0f13;
        --bg-elev: #181a21;
        --bg-card: #1c1f28;
        --border: #2a2e3a;
        --text: #e8eaf0;
        --muted: #9aa0b0;
        --accent: #6ee7a8; /* slime green */
        --accent-2: #f06595; /* mushroom pink */
        --radius: 14px;
        --max: 1080px;
      }

      * {
        box-sizing: border-box;
      }
      html {
        color-scheme: dark;
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        font-family:
          system-ui, -apple-system, 'Hiragino Kaku Gothic ProN',
          'Hiragino Sans', 'Noto Sans JP', Meiryo, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.75;
        -webkit-font-smoothing: antialiased;
      }
      a {
        color: inherit;
      }
      img {
        max-width: 100%;
        display: block;
      }

      main {
        flex: 1;
        width: 100%;
        max-width: var(--max);
        margin: 0 auto;
        padding: 0 20px 80px;
      }

      /* header / footer */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        background: color-mix(in srgb, var(--bg) 82%, transparent);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--border);
      }
      .site-header .inner,
      .site-footer .inner {
        max-width: var(--max);
        margin: 0 auto;
        padding: 16px 20px;
      }
      .brand {
        font-weight: 800;
        letter-spacing: 0.04em;
        text-decoration: none;
        font-size: 1.15rem;
      }
      .site-footer {
        border-top: 1px solid var(--border);
        color: var(--muted);
        font-size: 0.85rem;
      }

      /* hero (top) */
      .hero {
        padding: 56px 0 40px;
      }
      .hero h1 {
        margin: 0 0 8px;
        font-size: clamp(2rem, 5vw, 3rem);
        letter-spacing: 0.02em;
      }
      .hero p {
        margin: 0;
        color: var(--muted);
        font-size: 1.05rem;
      }

      /* grid */
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 22px;
      }

      /* card */
      .card {
        display: flex;
        flex-direction: column;
        text-decoration: none;
        color: inherit;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        transition:
          transform 0.18s ease,
          border-color 0.18s ease,
          box-shadow 0.18s ease;
      }
      .card:hover {
        transform: translateY(-4px);
        border-color: color-mix(in srgb, var(--accent) 50%, var(--border));
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.35);
      }
      .card .thumb {
        aspect-ratio: 16 / 9;
        background: var(--bg-elev);
      }
      .card .thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .card .thumb .placeholder {
        width: 100%;
        height: 100%;
        display: grid;
        place-items: center;
        padding: 12px;
        text-align: center;
        font-weight: 700;
        color: var(--muted);
        background: linear-gradient(135deg, #1b2430, #0e0f13);
      }
      .card .body {
        padding: 16px 18px 20px;
        display: flex;
        flex-direction: column;
        gap: 6px;
      }
      .card .body h2 {
        margin: 0;
        font-size: 1.2rem;
      }
      .card .body p {
        margin: 0;
        color: var(--muted);
        font-size: 0.92rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      /* badge */
      .badge {
        align-self: flex-start;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        padding: 3px 9px;
        border-radius: 999px;
        color: var(--accent);
        background: color-mix(in srgb, var(--accent) 14%, transparent);
        border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
      }

      /* detail page */
      .back {
        display: inline-block;
        margin: 28px 0 8px;
        color: var(--muted);
        text-decoration: none;
        font-size: 0.9rem;
      }
      .back:hover {
        color: var(--text);
      }
      .detail .cover {
        margin: 8px 0 28px;
        border-radius: var(--radius);
        overflow: hidden;
        border: 1px solid var(--border);
      }
      .detail .cover img {
        width: 100%;
        aspect-ratio: 16 / 9;
        object-fit: cover;
      }
      .detail h1 {
        margin: 0 0 14px;
        font-size: clamp(1.8rem, 4vw, 2.6rem);
      }
      .detail .meta {
        list-style: none;
        margin: 0 0 18px;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 10px 22px;
        color: var(--muted);
        font-size: 0.9rem;
      }
      .detail .meta li span {
        display: block;
        font-size: 0.72rem;
        letter-spacing: 0.04em;
        color: color-mix(in srgb, var(--muted) 75%, transparent);
      }
      .detail .meta li {
        color: var(--text);
      }
      .detail .links {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 32px;
      }
      .detail .links a {
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 600;
        padding: 8px 16px;
        border-radius: 10px;
        border: 1px solid var(--border);
        background: var(--bg-elev);
        transition:
          border-color 0.18s ease,
          background 0.18s ease;
      }
      .detail .links a:hover {
        border-color: color-mix(in srgb, var(--accent) 55%, var(--border));
        background: color-mix(in srgb, var(--accent) 10%, var(--bg-elev));
      }

      /* prose (markdown 本文) */
      .prose {
        font-size: 1.02rem;
      }
      .prose > :first-child {
        margin-top: 0;
      }
      .prose h2 {
        margin: 2em 0 0.6em;
        padding-bottom: 0.3em;
        border-bottom: 1px solid var(--border);
        font-size: 1.4rem;
      }
      .prose h3 {
        margin: 1.6em 0 0.5em;
        font-size: 1.15rem;
      }
      .prose a {
        color: var(--accent);
      }
      .prose code {
        background: var(--bg-elev);
        padding: 0.15em 0.4em;
        border-radius: 6px;
        font-size: 0.9em;
      }
      .prose pre {
        background: var(--bg-elev);
        padding: 16px;
        border-radius: 10px;
        overflow-x: auto;
        border: 1px solid var(--border);
      }
      .prose pre code {
        background: none;
        padding: 0;
      }
      .prose img {
        border-radius: 10px;
        margin: 1em 0;
      }
      .prose table {
        border-collapse: collapse;
        width: 100%;
        margin: 1.2em 0;
        font-size: 0.95rem;
      }
      .prose th,
      .prose td {
        border: 1px solid var(--border);
        padding: 8px 12px;
        text-align: left;
      }
      .prose th {
        background: var(--bg-elev);
      }
      .prose blockquote {
        margin: 1.2em 0;
        padding: 0.4em 1em;
        border-left: 3px solid var(--accent);
        color: var(--muted);
      }

      /* empty state */
      .empty {
        padding: 60px 0;
        color: var(--muted);
        text-align: center;
      }
    </style>
  </body>
</html>
