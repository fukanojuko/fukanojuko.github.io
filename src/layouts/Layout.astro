---
import { SITE_TITLE, SITE_DESCRIPTION, SECTIONS } from '../consts';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string; // OGP用。public配下の絶対パス（例: /images/foo.png）
  bodyClass?: string; // ページ単位でスタイルをスコープしたいとき用
}

const {
  title,
  description = SITE_DESCRIPTION,
  image,
  bodyClass = '',
} = Astro.props;

const pageTitle = title === SITE_TITLE ? title : `${title}｜${SITE_TITLE}`;
const ogImage = image ? new URL(image, Astro.site).toString() : undefined;
const year = new Date().getFullYear();
const current = Astro.url.pathname;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#main">本文へスキップ</a>

    <header class="site-header">
      <a href="/" class="brand">{SITE_TITLE}</a>
      <nav class="nav" aria-label="メインナビ">
        {
          SECTIONS.map((s) => (
            <a
              href={s.path}
              class:list={[{ active: current.startsWith(s.path) }]}
              aria-current={current.startsWith(s.path) ? 'page' : undefined}
            >
              {s.label}
            </a>
          ))
        }
      </nav>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">© {year} {SITE_TITLE} ／ ゲーム制作</div>
    </footer>
  </body>
</html>
